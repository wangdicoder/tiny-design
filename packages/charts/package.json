{
  "name": "@tiny-design/charts",
  "version": "1.6.1",
  "description": "Theme-aware chart components for Tiny Design, built on Recharts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wangdicoder/tiny-design.git",
    "directory": "packages/charts"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "lib/index.js",
  "module": "es/index.js",
  "typings": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./lib/*": "./lib/*",
    "./es/*": "./es/*"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "lib",
    "es"
  ],
  "scripts": {
    "build": "npm run clean && tsdown",
    "clean": "rimraf lib es"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "recharts": ">=2.0.0"
  },
  "dependencies": {
    "@tiny-design/tokens": "workspace:*",
    "classnames": "^2.3.1",
    "tslib": "^2.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.15.0",
    "rimraf": "^3.0.2",
    "tsdown": "^0.21.1",
    "typescript": "^5.4.0"
  }
}
