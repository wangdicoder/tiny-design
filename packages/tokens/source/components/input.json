  "input.border": {
    "$value": "{color-border}",
    "$type": "color",
    "description": "Input border color.",
    "fallback": "--ty-color-border"
  },
  "input.border.hover": {
    "$value": "{color-primary}",
    "$type": "color",
    "description": "Input hover border color.",
    "fallback": "--ty-color-primary"
