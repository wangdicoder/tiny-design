{
  "input.radius": {
    "$value": "{border-radius}",
    "$type": "dimension",
    "description": "Input border radius.",
    "fallback": "--ty-border-radius"
  },
  "input.color": {
    "$value": "{color-text}",
    "$type": "color",
    "description": "Input text color.",
    "fallback": "--ty-color-text"
  },
  "input.bg": {
    "$value": "{color-bg-container}",
    "$type": "color",
    "description": "Input background color.",
    "fallback": "--ty-color-bg-container"
