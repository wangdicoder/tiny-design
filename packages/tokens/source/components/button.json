    "fallback": "--ty-height-sm"
  },
  "button.height.md": {
    "$value": "{control.height.md}",
    "$type": "dimension",
    "description": "Medium button height.",
    "fallback": "--ty-height-md"
  },
  "button.height.lg": {
    "$value": "{control.height.lg}",
    "$type": "dimension",
    "description": "Large button height.",
    "fallback": "--ty-height-lg"
