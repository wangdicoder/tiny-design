  "input-number.input-padding-inline-start": {
    "$value": "7px",
    "$type": "dimension",
    "description": "Input Number input leading padding."
  },
  "input-number.input-padding-inline-end": {
    "$value": "25px",
    "$type": "dimension",
    "description": "Input Number input trailing padding."
  },
  "input-number.controls-padding": {
    "$value": "1px",
