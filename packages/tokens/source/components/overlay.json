    "$value": "{color-overlay-bg}",
    "$type": "color",
    "description": "Overlay default background color.",
    "fallback": "--ty-color-overlay-bg"
  },
  "overlay.bg.inverted": {
    "$value": "{color-overlay-inverted}",
    "$type": "color",
