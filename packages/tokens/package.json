{
  "name": "@tiny-design/tokens",
  "version": "1.14.0",
  "description": "Design tokens and v2 theme runtime for Tiny UI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wangdicoder/tiny-design.git",
    "directory": "packages/tokens"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "css/base.css",
  "exports": {
    ".": "./css/base.css",
    "./css/*": "./css/*",
    "./registry": "./dist/registry.json",
    "./registry-runtime": {
      "types": "./runtime/registry.d.ts",
      "import": "./runtime/registry.mjs",
      "require": "./runtime/registry.cjs"
    },
    "./presets": {
      "types": "./runtime/presets.d.ts",
      "import": "./runtime/presets.mjs",
      "require": "./runtime/presets.cjs"
    },
    "./resolve-theme": {
      "types": "./runtime/resolve-theme.d.ts",
      "import": "./runtime/resolve-theme.mjs",
      "require": "./runtime/resolve-theme.cjs"
    },
    "./compile-brand-theme": {
      "types": "./runtime/compile-brand-theme.d.ts",
      "import": "./runtime/compile-brand-theme.mjs",
      "require": "./runtime/compile-brand-theme.cjs"
    },
    "./validate-theme": {
      "types": "./runtime/validate-theme.d.ts",
      "import": "./runtime/validate-theme.mjs",
      "require": "./runtime/validate-theme.cjs"
    },
    "./dist/*": "./dist/*"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "css",
    "dist",
    "runtime"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "build:base-css": "node -e \"require('./scripts/build').buildBaseCss()\"",
    "build:runtime": "node scripts/build-runtime.js",
    "test": "node scripts/build-runtime.js --validate-only",
    "clean": "rimraf css dist"
  },
  "devDependencies": {
    "rimraf": "^3.0.2"
  }
}
